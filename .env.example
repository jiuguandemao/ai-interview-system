APP_NAME=AI-Interview
APP_ENV=development
DEBUG=true
SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+psycopg://ai_interview:ai_interview@db:5432/ai_interview
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
UPLOAD_DIR=/app/data/uploads
REPORT_DIR=/app/data/reports
MAX_UPLOAD_MB=10
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# OpenAI-compatible LLM. Keep mock=true until the basic workflow runs.
LLM_MOCK=true
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2

# Local Chinese embedding model. The first real run downloads model weights.
EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

LOG_LEVEL=INFO
